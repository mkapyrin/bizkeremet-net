---
import { HeroGeometric } from './ui/shape-landing-hero';
---
<section id="hero">
  <HeroGeometric
    client:load
    badge="🇰🇬 Кыргызстан, Бишкек"
    title1="Чистый бизнес"
    title2="в цифре"
  />
  <!-- Stats overlay -->
  <div class="relative -mt-32 z-20 pb-16">
    <div class="grid grid-cols-3 gap-8 max-w-lg mx-auto text-center">
      <div>
        <div class="text-3xl sm:text-4xl font-bold text-white">50+</div>
        <div class="text-sm text-gray-400 mt-1">проектов</div>
      </div>
      <div>
        <div class="text-3xl sm:text-4xl font-bold text-white">5+</div>
        <div class="text-sm text-gray-400 mt-1">лет опыта</div>
      </div>
      <div>
        <div class="text-3xl sm:text-4xl font-bold text-white">30+</div>
        <div class="text-sm text-gray-400 mt-1">клиентов</div>
      </div>
    </div>
  </div>
</section>
