---
const projects = [
  {
    title: 'E-commerce платформа',
    category: 'Веб-разработка',
    description: 'Интернет-магазин с интеграцией платёжных систем и CRM для крупного ритейлера.',
    gradient: 'from-blue-500 to-cyan-500',
  },
  {
    title: 'Мобильный банкинг',
    category: 'Мобильное приложение',
    description: 'Приложение для управления финансами с биометрической аутентификацией.',
    gradient: 'from-emerald-500 to-teal-500',
  },
  {
    title: 'Логистическая система',
    category: 'Веб-приложение',
    description: 'Система управления доставкой с GPS-трекингом и аналитикой в реальном времени.',
    gradient: 'from-violet-500 to-purple-500',
  },
  {
    title: 'HR-портал',
    category: 'IT-аутсорсинг',
    description: 'Корпоративный портал для управления персоналом с модулем обучения.',
    gradient: 'from-orange-500 to-red-500',
  },
  {
    title: 'Образовательная платформа',
    category: 'Веб-разработка',
    description: 'LMS-система с видеоуроками, тестированием и аналитикой успеваемости.',
    gradient: 'from-pink-500 to-rose-500',
  },
  {
    title: 'Приложение доставки еды',
    category: 'Мобильное приложение',
    description: 'Агрегатор ресторанов с отслеживанием заказа и интеграцией с кухней.',
    gradient: 'from-amber-500 to-yellow-500',
  },
];
---
<section id="portfolio" class="py-24 bg-bg">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <span class="text-primary font-semibold text-sm tracking-wider uppercase">Наши работы</span>
      <h2 class="text-3xl sm:text-4xl font-bold mt-3">Портфолио</h2>
      <p class="text-text-light mt-4 max-w-2xl mx-auto">Избранные проекты, которыми мы гордимся</p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {projects.map(project => (
        <div class="group relative rounded-2xl overflow-hidden bg-white border border-gray-100 hover:shadow-xl transition-all duration-300">
          <div class={`h-48 bg-gradient-to-br ${project.gradient} flex items-center justify-center`}>
            <svg class="w-16 h-16 text-white/30 group-hover:text-white/50 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
          </div>
          <div class="p-6">
            <span class="text-xs font-semibold text-primary bg-primary/10 px-3 py-1 rounded-full">{project.category}</span>
            <h3 class="text-lg font-bold mt-3 mb-2">{project.title}</h3>
            <p class="text-sm text-text-light leading-relaxed">{project.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
