---
const services = [
  {
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>`,
    title: 'Веб-разработка',
    description: 'Создаём быстрые и современные сайты, веб-приложения и интернет-магазины на актуальном стеке технологий.',
    features: ['Next.js / Astro', 'React / Vue', 'Node.js / Python', 'PostgreSQL / MongoDB'],
  },
  {
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>`,
    title: 'Мобильные приложения',
    description: 'Нативные и кроссплатформенные мобильные приложения для iOS и Android с фокусом на UX.',
    features: ['React Native', 'Flutter', 'iOS / Android', 'Push-уведомления'],
  },
  {
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>`,
    title: 'IT-аутсорсинг',
    description: 'Выделенные команды разработчиков, техническая поддержка и сопровождение проектов любой сложности.',
    features: ['Выделенные команды', 'DevOps / CI/CD', 'Техподдержка 24/7', 'Консалтинг'],
  },
];
---
<section id="services" class="py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <span class="text-primary font-semibold text-sm tracking-wider uppercase">Что мы делаем</span>
      <h2 class="text-3xl sm:text-4xl font-bold mt-3">Наши услуги</h2>
      <p class="text-text-light mt-4 max-w-2xl mx-auto">Полный цикл разработки цифровых продуктов — от идеи до запуска и поддержки</p>
    </div>

    <div class="grid md:grid-cols-3 gap-8">
      {services.map(service => (
        <div class="group p-8 rounded-2xl border border-gray-100 hover:border-primary/20 bg-white hover:shadow-xl hover:shadow-primary/5 transition-all duration-300">
          <div class="w-14 h-14 rounded-xl bg-primary/10 text-primary flex items-center justify-center mb-6 group-hover:bg-primary group-hover:text-white transition-colors">
            <Fragment set:html={service.icon} />
          </div>
          <h3 class="text-xl font-bold mb-3">{service.title}</h3>
          <p class="text-text-light mb-6 leading-relaxed">{service.description}</p>
          <ul class="space-y-2">
            {service.features.map(f => (
              <li class="flex items-center gap-2 text-sm text-text-light">
                <svg class="w-4 h-4 text-secondary flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                {f}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
